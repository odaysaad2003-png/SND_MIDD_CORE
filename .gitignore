# =========================
# Dependencies
# =========================
node_modules/
*/node_modules/

# =========================
# Environment variables
# Never commit secrets
# =========================
.env
.env.*
!.env.example

# =========================
# Build outputs
# =========================
dist/
build/
out/
.next/
.vercel/
*.tsbuildinfo

# =========================
# Logs
# =========================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =========================
# Runtime / cache
# =========================
.cache/
.tmp/
temp/
tmp/

# =========================
# Testing / coverage
# =========================
coverage/
.nyc_output/

# =========================
# Package managers
# =========================
.pnpm-store/

# =========================
# Local uploads and data
# =========================
uploads/
/storage/
/data/
*.sqlite
*.sqlite3

# =========================
# Editor files
# =========================
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/

# =========================
# Operating system files
# =========================
.DS_Store
Thumbs.db
desktop.ini

# =========================
# Docker local overrides
# =========================
docker-compose.override.yml

# =========================
# Production secrets / certificates
# =========================
*.pem
*.key
*.cert
*.crt

# =========================
# Git backup folders
# =========================
.git_backup_bad_history/
.git_backup*/